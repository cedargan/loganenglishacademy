  // 'url' is the full URL or relative path to the audio file.
  chapters: [
    { title: 'Chapter 1',  url: 'https://audio.loganenglishacademy.com/Hatchet/01%20Chapter%201.mp3' },
    { title: 'Chapter 2',  url: 'https://audio.loganenglishacademy.com/Hatchet/02%20Chapter%202.mp3' },
    { title: 'Chapter 3',  url: 'https://audio.loganenglishacademy.com/Hatchet/03%20Chapter%203.mp3' },
    { title: 'Chapter 4',  url: 'https://audio.loganenglishacademy.com/Hatchet/04%20Chapter%204.mp3' },
    { title: 'Chapter 5',  url: 'https://audio.loganenglishacademy.com/Hatchet/05%20Chapter%205.mp3' },
    { title: 'Chapter 6',  url: 'https://audio.loganenglishacademy.com/Hatchet/06%20Chapter%206.mp3' },
    { title: 'Chapter 7',  url: 'https://audio.loganenglishacademy.com/Hatchet/07%20Chapter%207.mp3' },
    { title: 'Chapter 8',  url: 'https://audio.loganenglishacademy.com/Hatchet/08%20Chapter%208.mp3' },
    { title: 'Chapter 9',  url: 'https://audio.loganenglishacademy.com/Hatchet/09%20Chapter%209.mp3' },
    { title: 'Chapter 10', url: 'https://audio.loganenglishacademy.com/Hatchet/10%20Chapter%2010.mp3' },
    { title: 'Chapter 11', url: 'https://audio.loganenglishacademy.com/Hatchet/11%20Chapter%2011.mp3' },
    { title: 'Chapter 12', url: 'https://audio.loganenglishacademy.com/Hatchet/12%20Chapter%2012.mp3' },
    { title: 'Chapter 13', url: 'https://audio.loganenglishacademy.com/Hatchet/13%20Chapter%2013.mp3' },
    { title: 'Chapter 14', url: 'https://audio.loganenglishacademy.com/Hatchet/14%20Chapter%2014.mp3' },
    { title: 'Chapter 15', url: 'https://audio.loganenglishacademy.com/Hatchet/15%20Chapter%2015.mp3' },
    { title: 'Chapter 16', url: 'https://audio.loganenglishacademy.com/Hatchet/16%20Chapter%2016.mp3' },
    { title: 'Chapter 17', url: 'https://audio.loganenglishacademy.com/Hatchet/17%20Chapter%2017.mp3' },
    { title: 'Chapter 18', url: 'https://audio.loganenglishacademy.com/Hatchet/18%20Chapter%2018.mp3' },
    { title: 'Chapter 19', url: 'https://audio.loganenglishacademy.com/Hatchet/19%20Chapter%2019.mp3' },
    { title: 'Epilogue',   url: 'https://audio.loganenglishacademy.com/Hatchet/20%20Epilogue.mp3' },
  ]
};
</script>
<!-- ════════════════════════════════════════
     END CONFIGURATION
     ════════════════════════════════════════ -->

<header class="header">
  <a class="header-logo" id="home-link" href="#">
    <img id="logo-img" src="" alt="" />
    <div class="header-name">
      <span id="hdr-tagline"></span>
      <span id="hdr-name"></span>
    </div>
  </a>
  <a class="back-link" id="library-link" href="#">
    ← Reading Library
  </a>
</header>

<div class="banner">
  <div class="banner-badge" id="book-emoji"></div>
  <div>
    <div class="banner-title" id="book-title"></div>
    <div class="banner-author" id="book-author"></div>
  </div>
  <div class="banner-meta">
    <div class="meta-num" id="chapter-count"></div>
    <div class="meta-label">Chapters</div>
  </div>
</div>

<div class="chapter-list" id="chapter-list"></div>

<footer>
  <strong id="footer-name"></strong> — Audio files are for enrolled students only.
</footer>

<script>
  const C = CONFIG;

  document.title = C.bookTitle + ' Audio — ' + C.academyName;
  document.getElementById('home-link').href     = C.homeUrl;
  document.getElementById('library-link').href  = C.libraryUrl;
  document.getElementById('logo-img').src       = C.logoSrc;
  document.getElementById('logo-img').alt       = C.academyName + ' logo';
  document.getElementById('hdr-name').textContent    = C.academyName;
  document.getElementById('hdr-tagline').textContent = C.academyTagline;
  document.getElementById('book-emoji').textContent  = C.bookEmoji;
  document.getElementById('book-title').textContent  = C.bookTitle;
  document.getElementById('book-author').textContent = C.bookAuthor;
  document.getElementById('chapter-count').textContent = C.chapters.length;
  document.getElementById('footer-name').textContent = C.academyName;

  const dlIcon = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v13M7 11l5 5 5-5M3 20h18"/></svg>`;

  const list = document.getElementById('chapter-list');
  C.chapters.forEach((ch, i) => {
    const card = document.createElement('div');
    card.className = 'chapter-card';
    const filename = ch.url.split('/').pop();
    card.innerHTML = `
      <div class="chapter-top">
        <div class="ch-num">${i + 1}</div>
        <div class="ch-title">${ch.title}</div>
        <a class="ch-download" href="${ch.url}" download="${decodeURIComponent(filename)}" aria-label="Download ${ch.title}">
          ${dlIcon}<span>Download</span>
        </a>
      </div>
      <div class="ch-player">
        <audio controls preload="none" src="${ch.url}" aria-label="${ch.title}"></audio>
      </div>`;
    list.appendChild(card);
  });
</script>

</body>
</html>
