<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Audio</title>
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --blue: #29ABE2;
      --blue-dark: #1a8fbd;
      --blue-dim: #e8f7fd;
      --yellow: #FFE500;
      --yellow-dark: #c9b500;
      --text: #1a1a1a;
      --text-muted: #666;
      --bg: #f5f7fa;
      --white: #ffffff;
      --border: #e0e4ea;
      --radius: 12px;
    }

    body {
      font-family: 'Nunito', sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
    }

    /* ── Header ── */
    .header {
      background: var(--blue);
      padding: 0 1.5rem;
      height: 64px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .header-logo {
      display: flex;
      align-items: center;
      gap: 10px;
      text-decoration: none;
    }
    .header-logo img {
      height: 38px;
      width: auto;
    }
    .header-name {
      font-size: 16px;
      font-weight: 800;
      color: var(--white);
      line-height: 1.2;
    }
    .header-name span {
      display: block;
      font-size: 11px;
      font-weight: 600;
      color: rgba(255,255,255,0.7);
      letter-spacing: 0.03em;
    }
    .back-link {
      font-size: 13px;
      font-weight: 600;
      color: rgba(255,255,255,0.85);
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 5px;
      transition: color 0.15s;
    }
    .back-link:hover { color: #fff; }

    /* ── Book banner ── */
    .banner {
      background: var(--white);
      border-bottom: 1px solid var(--border);
      padding: 1.5rem;
      display: flex;
      align-items: center;
      gap: 1.25rem;
    }
    .banner-badge {
      width: 52px;
      height: 52px;
      border-radius: 10px;
      background: var(--yellow);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      font-size: 26px;
    }
    .banner-title {
      font-size: 1.35rem;
      font-weight: 800;
      color: var(--text);
      line-height: 1.2;
    }
    .banner-author {
      font-size: 14px;
      color: var(--text-muted);
      margin-top: 2px;
    }
    .banner-meta {
      margin-left: auto;
      text-align: right;
      flex-shrink: 0;
    }
    .meta-num {
      font-size: 1.6rem;
      font-weight: 800;
      color: var(--blue);
      line-height: 1;
    }
    .meta-label {
      font-size: 12px;
      color: var(--text-muted);
      font-weight: 600;
    }

    /* ── Chapter list ── */
    .chapter-list {
      max-width: 720px;
      margin: 1.5rem auto;
      padding: 0 1rem 3rem;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .chapter-card {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
    }

    .chapter-top {
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 1rem 1.25rem;
    }

    .ch-num {
      width: 36px;
      height: 36px;
      border-radius: 8px;
      background: var(--blue-dim);
      color: var(--blue-dark);
      font-size: 14px;
      font-weight: 800;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .ch-title {
      font-size: 15px;
      font-weight: 700;
      flex: 1;
    }

    .ch-download {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 13px;
      font-weight: 700;
      color: var(--blue-dark);
      text-decoration: none;
      padding: 6px 14px;
      border-radius: 8px;
      border: 2px solid var(--blue);
      background: transparent;
      transition: all 0.15s;
      white-space: nowrap;
      flex-shrink: 0;
    }
    .ch-download:hover {
      background: var(--blue);
      color: var(--white);
    }
    .ch-download svg {
      width: 14px;
      height: 14px;
      flex-shrink: 0;
    }

    .ch-player {
      padding: 0 1.25rem 1rem;
    }
    .ch-player audio {
      width: 100%;
      height: 40px;
      border-radius: 8px;
      display: block;
    }

    /* ── Footer ── */
    footer {
      text-align: center;
      padding: 1.5rem;
      font-size: 13px;
      color: var(--text-muted);
      border-top: 1px solid var(--border);
    }
    footer strong { color: var(--blue-dark); }

    @media (max-width: 560px) {
      .banner { flex-wrap: wrap; }
      .banner-meta { margin-left: 0; text-align: left; }
      .header-name span { display: none; }
      .ch-download span { display: none; }
      .ch-download { padding: 6px 10px; }
    }
  </style>
</head>
<body>

<!-- ════════════════════════════════════════
     CONFIGURATION — only edit this section
     ════════════════════════════════════════ -->
<script>
const CONFIG = {

  // ── Academy info ──────────────────────────────
  academyName:   'Logan English Academy',
  academyTagline: 'Reading Library',
  logoSrc:       '/logo.png',        // path to your logo file
  homeUrl:       '/',                // where the back button links
  libraryUrl:    '/reading/',        // where "Reading Library" links

  // ── Book info ─────────────────────────────────
